{
  "name": "demo-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of standalone demo apps that share a common @demo/ui package.",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --recursive --filter \"./apps/*\" run build",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test",
    "typecheck": "pnpm --recursive run typecheck",
    "dev:kddi": "pnpm --filter kddi-noc-dashboard dev",
    "dev:nab": "pnpm --filter nab-landing dev",
    "dev:naukri": "pnpm --filter naukri-job-portal dev",
    "dev:paytm": "pnpm --filter paytm-web-demo dev",
    "dev:seek": "pnpm --filter seek-marketplace-demo dev",
    "dev:spark": "pnpm --filter spark-nz-demo dev",
    "dev:squiz": "pnpm --filter squiz-website-demo dev",
    "dev:changi": "pnpm --filter changi-airport-demo dev",
    "dev:nine": "pnpm --filter nine-com-au-demo dev",
    "build:kddi": "pnpm --filter kddi-noc-dashboard build",
    "build:nab": "pnpm --filter nab-landing build",
    "build:naukri": "pnpm --filter naukri-job-portal build",
    "build:paytm": "pnpm --filter paytm-web-demo build",
    "build:seek": "pnpm --filter seek-marketplace-demo build",
    "build:spark": "pnpm --filter spark-nz-demo build",
    "build:squiz": "pnpm --filter squiz-website-demo build",
    "build:changi": "pnpm --filter changi-airport-demo build",
    "build:nine": "pnpm --filter nine-com-au-demo build",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\" --ignore-path .gitignore",
    "dev:optus": "pnpm --filter optus-website-demo dev",
    "build:optus": "pnpm --filter optus-website-demo build"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@tailwindcss/oxide"
    ]
  }
}
