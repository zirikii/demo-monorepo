# Server-only Cursor API key for @cursor/sdk cloud agents (never prefix with VITE_)
# Generate from Cursor Dashboard → API Keys
CURSOR_API_KEY=

# Repository the remediation agent should work on
CURSOR_REPO_URL=https://github.com/zirikii/demo-monorepo
CURSOR_STARTING_REF=main

# Optional model id for Agent.create (default: composer-2.5)
# CURSOR_MODEL=composer-2.5
