{
  "name": "optus-noc-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Optus Network Operations demo — SNMP→RabbitMQ automation with Cursor Cloud Agent remediation (unofficial)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "shots": "playwright test e2e/vision.spec.ts"
  },
  "dependencies": {
    "@demo/ui": "workspace:*",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/outfit": "^5.2.6",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
