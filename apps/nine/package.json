{
  "name": "nine-news-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "nine.com.au website demo (unofficial) — Vite + React clone of Australia's Nine news, sport, lifestyle & entertainment portal",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@demo/ui": "workspace:*",
    "@fontsource/inter": "^5.2.7",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.13.0",
    "zod": "^3.24.1",
    "@hookform/resolvers": "^3.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
