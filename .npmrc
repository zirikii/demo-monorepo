# Keep each workspace app's dependency resolution isolated. These demos use
# different React versions (18 vs 19), so cross-app peer de-duplication and
# hoisting would leak the wrong @types/react into a project and break
# type-checking (e.g. React 19's ReactNode showing up in a React 18 app).
dedupe-peer-dependents=false

# Do not hoist the React typings into the shared virtual store; each app must
# resolve the @types/react that matches its own React version.
hoist-pattern[]=*
hoist-pattern[]=!@types/react
hoist-pattern[]=!@types/react-dom
